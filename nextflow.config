params {
    input_dir = "./data"
    out_count = "./results/count_summary_tsv"
    out_stats = "./results/stats_summary_tsv"
	db = "/root/blast_dbs"
	db_name = "nt_prok"
	out_alignment = "results/alignments"
	run_name = "default"
	lca_script = "LCA_BLAST_calculator/LCA_BLAST_calculator.py"
}

process {
	withName: 'COUNT_LINES' {
		cpus = 1
	}
	withName: 'GET_READ_STATS' {
		cpus = 1
	}
	withName: 'BLAST' {
		cpus = 10
	}

}
